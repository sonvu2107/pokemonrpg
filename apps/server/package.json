{
    "name": "server",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "nodemon src/index.js",
        "start": "node src/index.js",
        "lint": "eslint src --ext js",
        "reset:battle-trainer-progress": "node src/scripts/resetBattleTrainerProgress.js",
        "reset:battle-trainer-moon-points:dry": "node src/scripts/resetBattleTrainerMoonPoints.js --dry-run",
        "reset:battle-trainer-moon-points": "node src/scripts/resetBattleTrainerMoonPoints.js",
        "reset:user-moon-points:dry": "node src/resetUserMoonPoints.js",
        "reset:user-moon-points": "node src/resetUserMoonPoints.js --apply",
        "migrate:pokemon-move-ids:dry": "node scripts/migratePokemonMoveIds.js",
        "migrate:pokemon-move-ids": "node scripts/migratePokemonMoveIds.js --apply",
        "set:moves:learn-scope:move-type:dry": "node scripts/setMoveLearnScopeMoveType.js",
        "set:moves:learn-scope:move-type": "node scripts/setMoveLearnScopeMoveType.js --apply",
        "analyze:skill-effects": "node src/scripts/analyzeSkillEffectSpecs.js",
        "analyze:skill-effects:apply": "node src/scripts/analyzeSkillEffectSpecs.js --apply",
        "effects:add-to-skills": "node src/scripts/addEffectsToSkills.js",
        "test:effect-engine": "node src/scripts/testEffectEngine.js",
        "test:rate-limit": "node src/testGlobalRateLimit.js",
        "test:battle-attack-flow": "node src/scripts/testBattleAttackFlow.js",
        "test:skill-shop-teach-flow": "node scripts/testSkillShopTeachFlow.js",
        "chat:setup": "node src/scripts/setupChatDatabase.js",
        "chat:seed": "node src/scripts/seedChatMessages.js",
        "set:kanto:max-progress": "node src/scripts/setKantoMaxMapProgress.js",
        "benchmark:api": "node src/scripts/benchmarkApiPerf.js",
        "reset:pokemon-moves:dry": "node src/resetPokemonMoves.js --mode level-up-only",
        "reset:pokemon-moves": "node src/resetPokemonMoves.js --apply --mode level-up-only",
        "reset:pokemon-moves:all:dry": "node src/resetPokemonMoves.js --mode all",
        "reset:pokemon-moves:all": "node src/resetPokemonMoves.js --apply --mode all",
        "repair:party-indexes:dry": "node src/scripts/repairPartyIndexes.js",
        "repair:party-indexes": "node src/scripts/repairPartyIndexes.js --apply"
    },
    "dependencies": {
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "multer": "^2.0.2",
        "slugify": "^1.6.6",
        "socket.io": "^4.7.2"
    },
    "devDependencies": {
        "nodemon": "^3.0.2"
    }
}
